# ── REQUIRED ────────────────────────────────────────────────────
DATABASE_URL="postgresql://meetmit:meetmit_dev_only@localhost:5432/meetmit?schema=public"

# ── PRODUCTION ──────────────────────────────────────────────────
# API_SECRET must be a strong random string in production
# App will warn on startup if using the default
API_SECRET="change-me-in-production"

# ── OPTIONAL ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Cloud SQL (production only, alternative to DATABASE_URL)
# DB_USER=
# DB_PASSWORD=
# DB_NAME=
# DB_SOCKET=/cloudsql/project:region:instance
